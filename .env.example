# MySQL connection string (Aiven, PlanetScale, Railway, etc.)
DATABASE_URL="mysql://user:password@host:port/database?ssl-mode=REQUIRED"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# Your deployed URL (or http://localhost:3000 for local dev)
NEXTAUTH_URL="http://localhost:3000"

# Vercel Blob token — get this from vercel.com/[your-team]/stores
# after creating a Blob store and linking it to your project.
# In production on Vercel this is auto-injected; only needed for local dev.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
