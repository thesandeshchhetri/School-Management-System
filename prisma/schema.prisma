// Prisma schema for the School Management System
// Provider: MySQL (works with Aiven, PlanetScale, Railway, or any MySQL host)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------- Auth / Users ----------

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          Role
  isSuperAdmin  Boolean  @default(false) // only meaningful when role = ADMIN
  photoUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teacher Teacher?
  student Student?
  parent  Parent?

  @@index([role])
}

// ---------- People ----------

model Teacher {
  id       String @id @default(cuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone    String?
  subject  String? // primary subject specialty
  joinedOn DateTime @default(now())

  classesAsTeacher ClassRoom[]      @relation("ClassTeacher")
  subjectsTaught   SubjectTeacher[]
  timetableSlots   TimetableSlot[]

  @@index([userId])
}

model Parent {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone  String?

  children Student[]

  @@index([userId])
}

model Student {
  id            String    @id @default(cuid())
  userId        String?   @unique
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  admissionNo   String    @unique
  firstName     String
  lastName      String
  dateOfBirth   DateTime?
  gender        String?
  phone         String?
  address       String?
  photoUrl      String?
  enrolledOn    DateTime  @default(now())

  classRoomId String?
  classRoom   ClassRoom? @relation(fields: [classRoomId], references: [id], onDelete: SetNull)

  parentId String?
  parent   Parent? @relation(fields: [parentId], references: [id], onDelete: SetNull)

  attendances    Attendance[]
  gradeEntries   GradeEntry[]
  feeInvoices    FeeInvoice[]

  @@index([classRoomId])
  @@index([parentId])
}

// ---------- Academics structure ----------

model ClassRoom {
  id          String  @id @default(cuid())
  name        String  @unique // e.g. "Grade 8 - Section A"
  gradeLevel  Int
  section     String?
  capacity    Int     @default(40)

  classTeacherId String?
  classTeacher   Teacher? @relation("ClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)

  students        Student[]
  subjects        Subject[]
  timetableSlots  TimetableSlot[]
  exams           Exam[]
}

model Subject {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  classRoomId String?
  classRoom   ClassRoom? @relation(fields: [classRoomId], references: [id], onDelete: SetNull)

  teachers       SubjectTeacher[]
  timetableSlots TimetableSlot[]
  gradeEntries   GradeEntry[]
}

model SubjectTeacher {
  id        String  @id @default(cuid())
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([subjectId, teacherId])
}

// ---------- Attendance ----------

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime
  status    AttendanceStatus
  remarks   String?
  markedBy  String? // teacher user id

  @@unique([studentId, date])
  @@index([date])
}

// ---------- Exams / Grades ----------

model Exam {
  id          String   @id @default(cuid())
  name        String   // e.g. "Mid-Term 2026"
  classRoomId String
  classRoom   ClassRoom @relation(fields: [classRoomId], references: [id], onDelete: Cascade)
  examDate    DateTime
  maxMarks    Float    @default(100)

  gradeEntries GradeEntry[]
}

model GradeEntry {
  id         String   @id @default(cuid())
  examId     String
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  marksObtained Float
  grade      String?  // computed letter grade, e.g. "A"
  remarks    String?

  @@unique([examId, studentId, subjectId])
}

// ---------- Fees ----------

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
}

model FeeInvoice {
  id        String        @id @default(cuid())
  studentId String
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title     String        // e.g. "Term 1 Tuition"
  amount    Float
  dueDate   DateTime
  status    InvoiceStatus @default(UNPAID)
  createdAt DateTime      @default(now())

  payments FeePayment[]

  @@index([studentId])
  @@index([status])
}

model FeePayment {
  id        String     @id @default(cuid())
  invoiceId String
  invoice   FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Float
  paidOn    DateTime   @default(now())
  method    String?    // cash, card, bank transfer
  reference String?
}

// ---------- Timetable ----------

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model TimetableSlot {
  id          String    @id @default(cuid())
  classRoomId String
  classRoom   ClassRoom @relation(fields: [classRoomId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  day         Weekday
  startTime   String    // "09:00"
  endTime     String    // "09:45"
  room        String?

  @@index([classRoomId, day])
}

// ---------- Organization (branding & module toggles) ----------
// Single-row table — see lib/org.ts for the getOrCreate helper.

model Organization {
  id                String   @id @default(cuid())
  name              String   @default("Brightpath School")
  logoUrl           String?
  address           String?

  // Controls whether each module appears in navigation / is reachable at all.
  // Students & Teachers are considered core and are always shown.
  attendanceEnabled Boolean  @default(true)
  examsEnabled      Boolean  @default(true)
  feesEnabled       Boolean  @default(true)
  timetableEnabled  Boolean  @default(true)
  classesEnabled    Boolean  @default(true)

  updatedAt         DateTime @updatedAt
}
